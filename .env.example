# Copy to .env (or set as environment variables in Render / Fly / Railway)

# Bright Data Scraping Browser WebSocket endpoint.
# Format: wss://brd-customer-<CUSTOMER_ID>-zone-<ZONE_NAME>:<ZONE_PASSWORD>@brd.superproxy.io:9222
BRIGHT_DATA_WSS=wss://brd-customer-hl_xxxxxxxx-zone-rufus_driver:CHANGEME@brd.superproxy.io:9222

# Shared bearer token. n8n's Bright Data Scraping Service credential sends this as Authorization header.
# Generate one with: openssl rand -hex 32
SHARED_SECRET=replace-with-a-long-random-string

# Port the Express server listens on. Most platforms inject this; default 3000 for local.
PORT=3000
